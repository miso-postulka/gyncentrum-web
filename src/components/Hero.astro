---
const stats = [
  { number: '16', label: 'Rokov skúseností', hasPlus: true },
  { number: '3575', label: 'Pacientov', hasPlus: true },
  { number: '12', label: 'Odborníkov', hasPlus: false },
];
---

<section class="hero" id="home">
  <div class="hero__container container">
    <div class="hero__content">
      <h1 class="hero__title">Nadštandardná starostlivosť poskytovaná s úsmevom</h1>
      <p class="hero__description">
        Súkromná ambulancia gynekológie a pôrodníctva s komplexnou zdravotnou starostlivosťou pre ženy
      </p>
      <div class="hero__buttons">
        <a href="#contact" class="button button--primary">Objednať sa</a>
        <a href="#about" class="button button--outline">Zistiť viac</a>
      </div>
    </div>
    <div class="hero__image">
      <div class="hero__stats">
        {stats.map((stat) => (
          <div class="stat">
            <div class="stat__number" data-target={stat.number} data-plus={stat.hasPlus}>
              0{stat.hasPlus ? '+' : ''}
            </div>
            <div class="stat__label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
