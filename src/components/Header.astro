---
import logoImage from '../resources/logo.png';

const navItems = [
  { href: '#home', label: 'Domov' },
  { href: '#about', label: 'O nás' },
  { href: '#team', label: 'Náš tím' },
  { href: '#services', label: 'Vyšetrenia' },
  { href: '#hours', label: 'Ordinačné hodiny' },
  { href: '#contact', label: 'Kontakt' },
];
---

<header class="header" id="header">
  <nav class="nav container">
    <div class="nav__logo">
      <img src={logoImage.src} alt="Gyncentrum" class="nav__logo-img" />
      <span>Gyncentrum</span>
    </div>

    <div class="nav__menu" id="nav-menu">
      <ul class="nav__list">
        {navItems.map((item, index) => (
          <li class="nav__item">
            <a href={item.href} class={`nav__link ${index === 0 ? 'active' : ''}`}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="nav__close" id="nav-close">
        <i class="fas fa-times"></i>
      </div>
    </div>

    <div class="nav__toggle" id="nav-toggle">
      <i class="fas fa-bars"></i>
    </div>
  </nav>
</header>
