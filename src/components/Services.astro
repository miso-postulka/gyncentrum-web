---
const services = [
  {
    icon: 'fa-stethoscope',
    title: 'Gynekologické vyšetrenia',
    description: 'Komplexné gynekologické vyšetrenia a liečba gynekologických ochorení'
  },
  {
    icon: 'fa-baby',
    title: 'Pôrodnícka starostlivosť',
    description: 'Sledovanie tehotenstva a kompletná pôrodnícka starostlivosť'
  },
  {
    icon: 'fa-ribbon',
    title: 'Ochorenia prsníka',
    description: 'Diagnostika a liečba ochorení prsníka'
  },
  {
    icon: 'fa-child',
    title: 'Detská gynekológia',
    description: 'Špecializovaná starostlivosť pre mladé pacientky'
  },
  {
    icon: 'fa-microscope',
    title: 'Moderné diagnostické metódy',
    description: 'Najnovšie diagnostické prístroje a vyšetrovacie metódy'
  },
  {
    icon: 'fa-heartbeat',
    title: 'Preventívna starostlivosť',
    description: 'Pravidelné preventívne prehliadky a skríning'
  }
];
---

<section class="services section" id="services">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Naše služby</h2>
      <p class="section__subtitle">Komplexné vyšetrenia a odborná starostlivosť</p>
    </div>

    <div class="services__container">
      {services.map((service) => (
        <div class="service__card">
          <div class="service__icon">
            <i class={`fas ${service.icon}`}></i>
          </div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
