---

<section class="hours section" id="hours">
  <div class="container">
    <div class="hours__container">
      <div class="hours__content">
        <h2>Ordinačné hodiny</h2>
        <p class="hours__description">Sme tu pre vás každý pracovný deň</p>

        <div class="hours__schedule">
          <div class="schedule__item">
            <i class="fas fa-clock"></i>
            <div>
              <strong>Pondelok - Piatok</strong>
              <p>7:00 - 17:00</p>
            </div>
          </div>
          <div class="schedule__item">
            <i class="fas fa-calendar-times"></i>
            <div>
              <strong>Sobota - Nedeľa</strong>
              <p>Zatvorené</p>
            </div>
          </div>
        </div>

        <div class="hours__note">
          <i class="fas fa-info-circle"></i>
          <p>Objednanie pacienta telefonicky alebo osobne v ambulancii</p>
        </div>
      </div>

      <div class="hours__cta">
        <div class="cta__card">
          <i class="fas fa-phone-alt"></i>
          <h3>Potrebujete objednanie?</h3>
          <p>Zavolajte nám alebo napíšte email</p>
          <a href="#contact" class="button button--primary">Kontaktovať nás</a>
        </div>
      </div>
    </div>
  </div>
</section>
